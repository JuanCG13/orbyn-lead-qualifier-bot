# Telegram BotFather token
TELEGRAM_BOT_TOKEN=

# Random secret used when setting the Telegram webhook. Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Public Vercel URL after deploy, e.g. https://orbyn-lead-qualifier-bot.vercel.app
APP_URL=

# OpenRouter
OPENROUTER_API_KEY=
# Recommended quality/price default for this task. Cheaper fallback is mistralai/mistral-nemo.
OPENROUTER_MODEL=openai/gpt-4.1-nano
OPENROUTER_FALLBACK_MODEL=mistralai/mistral-nemo

# Google Sheets service account
GOOGLE_SHEET_ID=
GOOGLE_CLIENT_EMAIL=
# Keep line breaks escaped in Vercel, e.g. -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
GOOGLE_PRIVATE_KEY=
